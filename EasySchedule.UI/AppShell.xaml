<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EasySchedule.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:EasySchedule.UI.Views"
    xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="{StaticResource Surface}">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="160" BackgroundColor="{StaticResource Primary}">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                <Border WidthRequest="64" HeightRequest="64" StrokeShape="RoundRectangle 32" BackgroundColor="#3B82F6" StrokeThickness="0">
                    <Label Text="ES" TextColor="White" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="EasySchedule" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
                <Label Text="Planowanie Obsady" TextColor="#DBEAFE" FontSize="12" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Zarządzaj Grafikami" Icon="{mi:Material Icon=CalendarMonth, IconColor=Black}">
        <ShellContent Route="SchedulesPage" ContentTemplate="{DataTemplate local:SchedulesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Pracownicy" Icon="{mi:Material Icon=People, IconColor=Black}">
        <ShellContent Route="EmployeesPage" ContentTemplate="{DataTemplate local:EmployeesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Profesje" Icon="{mi:Material Icon=Work, IconColor=Black}">
        <ShellContent Route="ProfessionsPage" ContentTemplate="{DataTemplate local:ProfessionsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Typy Zmian" Icon="{mi:Material Icon=Schedule, IconColor=Black}">
        <ShellContent Route="ShiftTypesPage" ContentTemplate="{DataTemplate local:ShiftTypesPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Urlopy i Zwolnienia" Icon="{mi:Material Icon=EventBusy, IconColor=Black}">
        <ShellContent Route="TimeOffsPage" ContentTemplate="{DataTemplate local:TimeOffsPage}" />
    </FlyoutItem>

</Shell>